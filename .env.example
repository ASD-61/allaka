# Copy to .env for local dev, and set the same keys in Render for production.
# NEVER commit the real .env (it's gitignored).

# --- Core ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Strong random string (>= 16 chars). REQUIRED in production.
SESSION_SECRET=put-a-long-random-string-here
ADMIN_PASSWORD=change-me

# --- WhatsApp (WasenderAPI) ---
WASENDER_API_TOKEN=your-wasender-token

# --- CORS (optional; needed only for the web build) ---
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# --- Image storage (S3-compatible: Cloudflare R2 / Supabase / Backblaze / AWS) ---
# When these are set, uploads go straight to the bucket and the API server
# never stores image bytes. Leave unset locally to use LOCAL_STORAGE_DIR instead.
# S3_BUCKET=alaka-images
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto

# --- Local-only image storage (dev fallback, ignored when S3_* is set) ---
LOCAL_STORAGE_DIR=./local-storage
