{
  "expo": {
    "name": "عـلاّكـة",
    "slug": "khudra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "khudra-mobile",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d018efd5-683c-47b5-8e32-2af41b3a5e41",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allaka.khudra"
    },
    "android": {
      "package": "com.allaka.khudra",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "allaka",
          "project": "allaka-mobile"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يستخدم التطبيق موقعك لتحديد عنوان التوصيل بدقة وإرساله للمتجر مع طلبك."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم التطبيق مكتبة الصور لرفع صور المنتجات والمتجر وبلاغات التعويض.",
          "cameraPermission": "يستخدم التطبيق الكاميرا لالتقاط صور المنتجات والمتجر وبلاغات التعويض.",
          "microphonePermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.facebook.hermes.unicode.** { *; }\n-keep class com.facebook.jni.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.swmansion.worklets.** { *; }\n-keep class com.th3rdwave.safeareacontext.** { *; }\n-keep class com.reactnativecommunity.webview.** { *; }\n-keep class com.horcrux.svg.** { *; }\n-keep class com.reactnativekeyboardcontroller.** { *; }\n-keep public class com.facebook.react.** { *; }\n-dontwarn com.facebook.react.**\n-dontwarn okhttp3.**\n-dontwarn okio.**"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "d018efd5-683c-47b5-8e32-2af41b3a5e41"
      }
    },
    "owner": "pq_173"
  }
}
